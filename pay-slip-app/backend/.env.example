# .env.example
# ENVIRONMENT (production or development. Use development for local testing without JWT)
ENVIRONMENT=development
PORT=8081

# Database configuration (MySQL — for users and pay slip metadata)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth configuration (same JWKS endpoint as the superapp identity provider)
JWKS_URL=

# Firebase Storage configuration (Cloud Storage for PDF files)
# Firebase Storage bucket (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=
# Path to a GCP service-account JSON key file (e.g., ./service-account.json).
# Required if deploying outside of Google Cloud.
# Leave empty ONLY if using Application Default Credentials on GCP / Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=